{
  "name": "@slango/tessera",
  "version": "1.0.22",
  "private": false,
  "description": "Collection of typescript utilities",
  "repository": {
    "type": "git",
    "url": "https://github.com/danilupion/slango",
    "directory": "packages/tessera"
  },
  "type": "module",
  "exports": {
    "./*": "./src/*.ts"
  },
  "scripts": {
    "build:check": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --run --coverage",
    "test:ui": "vitest --ui"
  },
  "devDependencies": {
    "@slango.configs/eslint": "workspace:*",
    "@slango.configs/typescript": "workspace:*",
    "@slango.configs/vitest": "workspace:*",
    "@vitest/coverage-v8": "4.1.7",
    "@vitest/ui": "4.1.7",
    "eslint": "10.4.0",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  }
}
