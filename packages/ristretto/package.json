{
  "name": "@slango/ristretto",
  "version": "1.0.37",
  "private": false,
  "description": "Opinionated rest client",
  "repository": {
    "type": "git",
    "url": "https://github.com/danilupion/slango",
    "directory": "packages/ristretto"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./abortable": {
      "import": "./dist/abortable/index.js",
      "types": "./dist/abortable/index.d.ts"
    },
    "./middleware": {
      "import": "./dist/middleware/index.js",
      "types": "./dist/middleware/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:force": "tsc -p tsconfig.build.json --incremental false",
    "build:watch": "tsc -p tsconfig.build.json --watch",
    "build:check": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --run --coverage",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@slango/tessera": "workspace:*"
  },
  "devDependencies": {
    "@slango.configs/eslint": "workspace:*",
    "@slango.configs/typescript": "workspace:*",
    "@slango.configs/vitest": "workspace:*",
    "@types/node": "25.6.0",
    "@vitest/coverage-v8": "4.1.5",
    "@vitest/ui": "4.1.5",
    "eslint": "10.3.0",
    "type-fest": "5.6.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
