{
  "name": "@slango.configs/eslint",
  "version": "1.2.13",
  "private": false,
  "description": "Slango eslint configs",
  "repository": {
    "type": "git",
    "url": "https://github.com/danilupion/slango",
    "directory": "configs/eslint"
  },
  "type": "module",
  "exports": {
